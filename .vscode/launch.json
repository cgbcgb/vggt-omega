                "/root/workspace/data/vggt_omega_data/input_pictures/20260523-213343.png",
                "/root/workspace/data/vggt_omega_data/input_pictures/20260523-213400.png",
                "/root/workspace/data/vggt_omega_data/input_pictures/20260523-213407.png",
                "/root/workspace/data/vggt_omega_data/input_pictures/20260523-213411.png",
                "/root/workspace/data/vggt_omega_data/input_pictures/20260523-213414.png",
