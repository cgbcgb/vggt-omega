{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "demo_gradio",
            "type": "debugpy",
            "request": "launch",
            "module": "demo_gradio",
            "args": [
                "--checkpoint",
                "/root/workspace/data/vggt_omega_data/pth/vggt_omega_1b_512.pt",
                "--image-resolution",
                "512"
            ],
            "cwd": "${workspaceFolder}",
